<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondoGrisClaro"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/imgBackdropPersona"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:src="@color/textoOscuro" />

        <View
            android:id="@+id/backdropOverlay"
            android:layout_width="0dp"
            android:layout_height="120dp"
            android:background="@drawable/gradient_backdrop_bottom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Columna izquierda con toda la info de la eprsona -->
        <LinearLayout
            android:id="@+id/columnaIzquierda"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="8dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@id/columnaDerecha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Foto perfil -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardFotoPersona"
                android:layout_width="140dp"
                android:layout_height="175dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="8dp">

                <ImageView
                    android:id="@+id/imgFotoPersona"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@string/foto"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/ic_launcher_foreground" />

            </androidx.cardview.widget.CardView>

            <!-- nombre -->
            <TextView
                android:id="@+id/tvNombrePersona"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:textColor="@color/textoOscuro"
                android:textSize="20dp"
                android:textStyle="bold"
                tools:text="Cate Blanchett" />

            <!-- departamento -->
            <TextView
                android:id="@+id/tvDepartamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="@color/textoGrisMedio"
                android:textSize="12dp"
                tools:text="Actuación · Dirección" />

            <!-- fecha y lugar nacimiento -->
            <LinearLayout
                android:id="@+id/layoutMetaPills"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginBottom="6dp"
                    android:background="@drawable/bg_spinner_pill"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_calendar"
                        app:tint="@color/colorBotonPendientes" />

                    <TextView
                        android:id="@+id/tvFechaNacimiento"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textoOscuro"
                        android:textSize="12dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_spinner_pill"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="12dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_location"
                        app:tint="@color/colorBotonPendientes" />

                    <TextView
                        android:id="@+id/tvLugarNacimiento"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textoOscuro"
                        android:textSize="12dp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Botón favorito -->
            <LinearLayout
                android:id="@+id/btnFavoritoPersona"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/btn_outline_dorado"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp">

                <ImageView
                    android:id="@+id/iconFavorito"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_heart_outline"
                    app:tint="@color/colorBotonPendientes" />

                <TextView
                    android:id="@+id/tvTextoFavorito"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/guardarEnFav"
                    android:textColor="@color/textoOscuro"
                    android:textSize="13dp"
                    android:textStyle="bold" />

            </LinearLayout>

        </LinearLayout>

        <!-- Columna derecha con biografía y conocido por -->
        <LinearLayout
            android:id="@+id/columnaDerecha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/columnaIzquierda"
            app:layout_constraintTop_toBottomOf="@id/imgBackdropPersona">

            <!-- label biografía -->
            <TextView
                android:id="@+id/labelBio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:letterSpacing="0.08"
                android:text="@string/bio"
                android:textAllCaps="true"
                android:textColor="@color/textoGrisMedio"
                android:textSize="10dp"
                android:textStyle="bold" />

            <!-- biografía -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardBiografia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:id="@+id/tvBiografia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:lineSpacingExtra="3dp"
                        android:maxLines="6"
                        android:textColor="@color/textoOscuro"
                        android:textSize="13dp" />

                    <TextView
                        android:id="@+id/tvLeerMas"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/leerMas"
                        android:textColor="@color/colorBotonPendientes"
                        android:textSize="12dp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- conocido por -->
            <TextView
                android:id="@+id/labelObras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:letterSpacing="0.08"
                android:text="@string/conocidoPor"
                android:textAllCaps="true"
                android:textColor="@color/textoGrisMedio"
                android:textSize="10dp"
                android:textStyle="bold" />


            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvObrasPersona"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:orientation="horizontal"
                android:paddingHorizontal="0dp"
                android:paddingBottom="4dp"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>