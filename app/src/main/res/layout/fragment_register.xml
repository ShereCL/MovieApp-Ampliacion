<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondoGrisClaro"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.2" />

        <!-- Icono TV -->
        <ImageView
            android:id="@+id/appIcon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_icon_login"
            android:contentDescription="@string/app_name"
            android:padding="16dp"
            android:src="@drawable/televisor" />

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:letterSpacing="-0.01"
            android:text="@string/crearCuenta"
            android:textColor="@color/textoNegro"
            android:textSize="24dp"
            android:textStyle="bold" />

        <!-- Subtítulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/msgRegister"
            android:textColor="@color/textoGrisMedio"
            android:textSize="14dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="28dp" />

        <!-- Card de inputs -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/colorFondoMenu"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/colorPuntuacion"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Label nombre -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:letterSpacing="0.06"
                    android:text="@string/nombreUsuario"
                    android:textAllCaps="true"
                    android:textColor="@color/amarilloDorado"
                    android:textSize="11dp"
                    android:textStyle="bold" />

                <!-- Campo nombre -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/nombreInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxStrokeColor="@color/colorPuntuacion"
                    app:boxStrokeErrorColor="@color/rojoEliminar"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etNombre"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/tuNombreDeUsuario"
                        android:inputType="textPersonName"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/colorBottomNavText"
                        android:textColorHint="@color/textoGrisMedio"
                        android:textSize="15dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Label email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:letterSpacing="0.06"
                    android:text="@string/msgCorreo"
                    android:textAllCaps="true"
                    android:textColor="@color/amarilloDorado"
                    android:textSize="11dp"
                    android:textStyle="bold" />

                <!-- Campo email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/emailInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxStrokeColor="@color/colorPuntuacion"
                    app:boxStrokeErrorColor="@color/rojoEliminar"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/emailEditText"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/correoEjemplo"
                        android:inputType="textEmailAddress"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/colorBottomNavText"
                        android:textColorHint="@color/textoGrisMedio"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Label contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:letterSpacing="0.06"
                    android:text="@string/contraseña"
                    android:textAllCaps="true"
                    android:textColor="@color/amarilloDorado"
                    android:textSize="11dp"
                    android:textStyle="bold" />

                <!-- Campo contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/passwordInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxStrokeColor="@color/colorPuntuacion"
                    app:boxStrokeErrorColor="@color/rojoEliminar"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/grisIcono"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/passwordEditText"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/ejemploPassword"
                        android:inputType="textPassword"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/colorBottomNavText"
                        android:textColorHint="@color/textoGrisMedio"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Helper contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginBottom="16dp"
                    android:text="@string/helpContraseña"
                    android:textColor="@color/textoGrisMedio"
                    android:textSize="11dp" />

                <!-- Label confirmar contraseña -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:letterSpacing="0.06"
                    android:text="@string/confirmContraseña"
                    android:textAllCaps="true"
                    android:textColor="@color/amarilloDorado"
                    android:textSize="11dp"
                    android:textStyle="bold" />

                <!-- Campo confirmar contraseña -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/confirmPasswordInputLayout"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:boxCornerRadiusBottomEnd="10dp"
                    app:boxCornerRadiusBottomStart="10dp"
                    app:boxCornerRadiusTopEnd="10dp"
                    app:boxCornerRadiusTopStart="10dp"
                    app:boxStrokeColor="@color/colorPuntuacion"
                    app:boxStrokeErrorColor="@color/rojoEliminar"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/grisIcono"
                    app:hintEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/confirmPasswordEditText"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:hint="@string/repitePassword"
                        android:inputType="textPassword"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:textColor="@color/colorBottomNavText"
                        android:textColorHint="@color/textoGrisMedio"
                        android:textSize="15sp" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.04"
                android:text="@string/fotoPerfil"
                android:textColor="@color/textoGrisMedio"
                android:textSize="12dp" />

            <FrameLayout
                android:id="@+id/fotoPerfilContainer"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:clickable="true"
                android:focusable="true">

                <!-- Imagen de perfil -->
                <ImageView
                    android:id="@+id/ivFotoPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_backgroud"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_add_foto" />
            </FrameLayout>

        </LinearLayout>

        <!-- Botón Crear cuenta -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/registerButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/colorBotonPendientes"
            android:elevation="4dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/creaCuenta"
            android:textAllCaps="false"
            android:textColor="@color/fondoToolbar"
            android:textSize="16dp"
            android:textStyle="bold"
            app:cornerRadius="14dp" />

        <!-- Divisor -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/grisIcono" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:text="@string/oRegistrate"
                android:textColor="@color/textoGrisMedio"
                android:textSize="12dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"
                android:background="@color/grisIcono" />
        </LinearLayout>

        <!-- Botón Google -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/googleSignInButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:backgroundTint="@color/colorFondoMenu"
            android:elevation="2dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/registerGoogle"
            android:textAllCaps="false"
            android:textColor="@color/textoNegro"
            android:textSize="15dp"
            app:cornerRadius="14dp"
            app:icon="@drawable/google"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconSize="22dp"
            app:iconTint="@null"
            app:strokeColor="@color/grisIcono"
            app:strokeWidth="1dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.3" />

        <!-- Ir al login -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/yaTienesCuenta"
                android:textColor="@color/textoGrisMedio"
                android:textSize="14dp" />

            <TextView
                android:id="@+id/goToLoginText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="@string/iniciarSesion"
                android:textColor="@color/amarilloDorado"
                android:textSize="14dp"
                android:textStyle="bold" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/amarilloDorado"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>