<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingTop="10dp"
    android:paddingEnd="16dp"
    android:paddingBottom="10dp">

    <!-- imagen de perfil -->
    <FrameLayout
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="2dp"
        android:layout_marginEnd="10dp">

        <ImageView
            android:id="@+id/ivAvatarComentario"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar_circle"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/tvInicialComentario"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_avatar_circle"
            android:gravity="center"
            android:textColor="@color/colorFondoMenu"
            android:textSize="14dp"
            android:textStyle="bold"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Contenido -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Nombre y fecha -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNombreComentario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/sinopsisColor"
                android:textSize="13dp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFechaComentario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:alpha="0.6"
                android:textColor="@color/textoGrisMedio"
                android:textSize="11dp" />

        </LinearLayout>

        <!-- Mensaje -->
        <TextView
            android:id="@+id/tvMensajeComentario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:alpha="0.85"
            android:lineSpacingExtra="2dp"
            android:maxLines="5"
            android:textColor="@color/sinopsisColor"
            android:textSize="13dp" />

    </LinearLayout>

</LinearLayout>