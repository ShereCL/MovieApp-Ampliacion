<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="6dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- miniatura serie/peli -->
            <ImageView
                android:id="@+id/imgPoster"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:contentDescription="@string/poster"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tvPendingStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="4dp"
                android:text="@string/yaEnPendientes"
                android:textColor="@color/naranjaPendientes"
                android:textSize="12dp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Título -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:text="@string/titulo"
                    android:textSize="18dp"
                    android:textStyle="bold" />

                <!-- Género -->
                <TextView
                    android:id="@+id/tvGenre"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/ejemplosGenero"
                    android:textColor="@color/colorFondoMiniatura"
                    android:textSize="13dp" />

                <!-- Info de la peli o serie -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvReleaseDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/anio"
                        android:textSize="13dp" />

                    <TextView
                        android:id="@+id/tvVoteAverage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/ejemploPuntuacion"
                        android:textSize="13dp" />
                </LinearLayout>

                <!-- resumen de la sinopsis -->
                <TextView
                    android:id="@+id/tvOverview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="3"
                    android:text="@string/sinopsisDefecto"
                    android:textColor="@color/colorSinopsisCard"
                    android:textSize="14dp" />

            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnAddPending"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/circle_backgroud"
            android:contentDescription="@string/add_pendientes"
            android:src="@drawable/btn_add"
            app:tint="@color/colorPuntuacion" />

        <com.gold24park.popcornview.popcornview.PopcornView
            android:id="@+id/popcornView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:visibility="gone"
            app:popcornAmount="30" />

    </FrameLayout>

</androidx.cardview.widget.CardView>