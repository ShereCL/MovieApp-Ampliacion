<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fondoGrisClaro"
    android:orientation="vertical">

    <!-- Buscador y filtros -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            app:boxBackgroundColor="@android:color/transparent"
            app:boxCornerRadiusBottomEnd="28dp"
            app:boxCornerRadiusBottomStart="28dp"
            app:boxCornerRadiusTopEnd="28dp"
            app:boxCornerRadiusTopStart="28dp"
            app:boxStrokeColor="@color/stroke_buscador"
            app:boxStrokeWidth="1.5dp"
            app:boxStrokeWidthFocused="1.5dp"
            app:hintEnabled="false"
            app:startIconDrawable="@drawable/ic_search"
            app:startIconTint="@color/textoGrisMedio">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBuscarPersona"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/buscarPersona"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:minHeight="46dp"
                android:paddingStart="0dp"
                android:singleLine="true"
                android:textColor="@color/textoOscuro"
                android:textColorHint="@color/textoGrisMedio"
                android:textSize="14dp" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Botón filtros -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFiltrosPersonas"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/amarilloDorado"
            app:cornerRadius="23dp"
            app:icon="@drawable/ic_filter"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            app:iconSize="20dp"
            app:iconTint="@color/white" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/panelFiltrosPersonas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/fondoBlanco"
        app:cardCornerRadius="14dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="6dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_filter"
                    app:tint="@color/amarilloDorado" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.08"
                    android:text="@string/filtros"
                    android:textColor="@color/textoGrisMedio"
                    android:textSize="10dp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- departamento (si es actor, director... en TMDB viene como departamento y por simplicidad lo he llamado así) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.06"
                android:text="@string/departamento"
                android:textAllCaps="true"
                android:textColor="@color/textoGrisMedio"
                android:textSize="10dp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupDepartamento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTodos"
                    style="@style/Widget.MovieApp.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:checked="true"
                    android:text="@string/todos" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipActing"
                    style="@style/Widget.MovieApp.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/acting" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipDirecting"
                    style="@style/Widget.MovieApp.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/directing" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipWriting"
                    style="@style/Widget.MovieApp.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/writing" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipProduction"
                    style="@style/Widget.MovieApp.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/production" />

            </com.google.android.material.chip.ChipGroup>

            <!-- Sección ordenar -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:letterSpacing="0.06"
                android:text="@string/ordenarPor"
                android:textAllCaps="true"
                android:textColor="@color/textoGrisMedio"
                android:textSize="10dp"
                android:textStyle="bold" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupOrden"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOrdenRelevancia"
                    style="@style/Widget.MovieApp.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:checked="true"
                    android:text="@string/relevancia" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOrdenAZ"
                    style="@style/Widget.MovieApp.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/nombreAZ" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipOrdenZA"
                    style="@style/Widget.MovieApp.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checkable="true"
                    android:text="@string/nombreZA" />

            </com.google.android.material.chip.ChipGroup>

            <!-- Botones -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLimpiarFiltrosPersonas"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:layout_marginEnd="8dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/limpiar"
                    android:textSize="12dp"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAplicarFiltrosPersonas"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/aplicar"
                    android:textSize="12dp"
                    app:backgroundTint="@color/amarilloDorado"
                    app:cornerRadius="18dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Lista -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPersonas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="8dp"
                android:paddingBottom="120dp" />

            <TextView
                android:id="@+id/tvSinResultados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="24dp"
                android:text="@string/buscaPersonaHint"
                android:textColor="@color/textoGrisMedio"
                android:textSize="14dp"
                android:visibility="gone" />

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>