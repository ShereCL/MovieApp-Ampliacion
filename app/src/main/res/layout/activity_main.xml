<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- AppBar superior -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp"
        app:liftOnScroll="true"
        android:theme="@style/ThemeOverlay.Material3.Light">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/fondoToolbarAmarillo"
            app:titleCentered="true"
            app:titleTextAppearance="@style/ToolbarTitle"
            app:navigationIconTint="@color/flechaBack"
            app:elevation="0dp"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Contenedor principal de fragments -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/nav_host_fragment"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:defaultNavHost="true"
        app:navGraph="@navigation/nav_graph"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:paddingBottom="56dp"
        android:clipToPadding="false"/>

    <!-- BottomNavigationView PRINCIPAL (Explorar, Pendientes...) -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        style="@style/BottomNavWithoutIndicator"
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/colorFondoMenu"
        app:menu="@menu/menu_bottom_main"
        app:labelVisibilityMode="labeled"
        app:itemBackground="@drawable/bottom_nav_item_bg"
        app:itemRippleColor="@android:color/transparent"
        app:itemIconTint="@color/ic_menu_tint"
        app:itemTextColor="@color/ic_menu_tint"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>